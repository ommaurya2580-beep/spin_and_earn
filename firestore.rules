rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Spin history subcollection
      match /spinHistory/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Referral codes - anyone can read, but only system can write
    match /referralCodes/{codeId} {
      allow read: if request.auth != null;
      allow write: if false; // Only server/admin can write
    }
    
    // Withdrawal requests - users can create and read their own
    match /withdrawalRequests/{requestId} {
      allow create: if request.auth != null 
        && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null 
        && resource.data.uid == request.auth.uid;
      allow update, delete: if false; // Only admin can update/delete
    }
  }
}
